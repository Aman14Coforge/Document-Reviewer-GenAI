MODEL_GARDEN_BASE_URL=https://your-model-garden-gateway-url
MODEL_GARDEN_API_KEY=your_api_key_here
LLM_MODEL=your_model_name_here

# Embeddings — provider: local | model_garden (or set in config/compliance.json)
EMBEDDING_PROVIDER=local

# Local embeddings (when EMBEDDING_PROVIDER=local)
# EMBEDDING_MODEL_PATH=model

# Model Garden embeddings (when EMBEDDING_PROVIDER=model_garden)
# EMBEDDING_API_URL=https://your-gateway-url/embeddings
# EMBEDDING_MODEL=your_embedding_model_name
# EMBEDDING_DIM=746
