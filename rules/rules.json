{
  "version": "1.0",
  "rules": [
    {
      "rule_id": "GDP-01",
      "title": "Document Title on First Page Matches File Name",
      "category": "header",
      "severity": "high",
      "rule_type": "semantic",
      "verifiable_criteria": "Check whether the main document title on the first page semantically matches the uploaded file name.",
      "validation_intent": "Ensure document identity consistency.",
      "typical_phrases": ["DEPLOYMENT REPORT", "SYSTEM VERSION 1.0"],
      "keywords": ["document title", "file name", "report name"],
      "applies_to_sections": ["first_page", "header"],
      "requires_metadata": ["file_name"]
    },
    {
      "rule_id": "GDP-02",
      "title": "Author Name and Role Are Mentioned",
      "category": "header",
      "severity": "medium",
      "rule_type": "semantic",
      "verifiable_criteria": "Check whether both author name and role are present.",
      "validation_intent": "Ensure accountability.",
      "typical_phrases": ["Prepared by", "Author", "NAME / TITLE"],
      "keywords": ["author", "role", "prepared by"],
      "applies_to_sections": ["first_page", "approval"]
    },
    {
      "rule_id": "GDP-03",
      "title": "Dates in Revision History Are Valid",
      "category": "revision_history",
      "severity": "medium",
      "rule_type": "deterministic",
      "verifiable_criteria": "Validate all revision dates are valid calendar dates.",
      "validation_intent": "Ensure accuracy of revision tracking.",
      "typical_phrases": ["REVISION HISTORY"],
      "keywords": ["revision date", "change log"],
      "applies_to_sections": ["revision_history"]
    },
    {
      "rule_id": "GDP-04",
      "title": "Version Number Present in Title and Revision History",
      "category": "revision_history",
      "severity": "high",
      "rule_type": "deterministic",
      "verifiable_criteria": "Check version consistency across title and revision history.",
      "validation_intent": "Ensure version traceability.",
      "typical_phrases": ["VERSION 1.0", "REVISION NO"],
      "keywords": ["version", "revision number"],
      "applies_to_sections": ["first_page", "header", "revision_history"]
    },
    {
      "rule_id": "GDP-05",
      "title": "Revision Section Is Present",
      "category": "revision_history",
      "severity": "medium",
      "rule_type": "deterministic",
      "verifiable_criteria": "Check if revision history section exists.",
      "validation_intent": "Ensure document tracking.",
      "typical_phrases": ["REVISION HISTORY"],
      "keywords": ["revision history", "change log"],
      "applies_to_sections": ["revision_history", "full"]
    },
    {
      "rule_id": "GDP-06",
      "title": "Signature Blocks Are Present",
      "category": "approval",
      "severity": "high",
      "rule_type": "deterministic",
      "verifiable_criteria": "Check approval/signature blocks exist.",
      "validation_intent": "Ensure formal approval.",
      "typical_phrases": ["SIGNATURE", "APPROVER"],
      "keywords": ["signature", "approval"],
      "applies_to_sections": ["approval"]
    },
    {
      "rule_id": "GDP-07",
      "title": "Dates Present Near Signatures",
      "category": "approval",
      "severity": "medium",
      "rule_type": "deterministic",
      "verifiable_criteria": "Check dates exist near signatures.",
      "validation_intent": "Ensure approval timestamps.",
      "typical_phrases": ["DATE", "SIGNED ON"],
      "keywords": ["date", "signature date"],
      "applies_to_sections": ["approval"]
    },
    {
      "rule_id": "GDP-08",
      "title": "Basic Font and Spacing Consistency",
      "category": "formatting",
      "severity": "low",
      "rule_type": "deterministic",
      "verifiable_criteria": "Check formatting consistency.",
      "validation_intent": "Ensure readability.",
      "typical_phrases": ["paragraph sections"],
      "keywords": ["font", "spacing"],
      "applies_to_sections": ["body", "full"],
      "always_include": true
    },
    {
      "rule_id": "GDP-09",
      "title": "Language Errors Identified",
      "category": "language",
      "severity": "medium",
      "rule_type": "semantic",
      "verifiable_criteria": "Detect grammar and spelling issues.",
      "validation_intent": "Ensure language quality.",
      "typical_phrases": ["text content"],
      "keywords": ["grammar", "spelling"],
      "applies_to_sections": ["body", "full"],
      "always_include": true
    },
    {
      "rule_id": "GDP-10",
      "title": "Required Sections Present",
      "category": "structure",
      "severity": "high",
      "rule_type": "semantic",
      "verifiable_criteria": "Check presence of mandatory sections.",
      "validation_intent": "Ensure completeness.",
      "typical_phrases": ["INTRODUCTION", "SCOPE"],
      "keywords": ["sections", "objective"],
      "applies_to_sections": ["structure", "full"],
      "always_include": true
    },
    {
      "rule_id": "GDP-11",
      "title": "Page Numbers Present and Sequential",
      "category": "footer",
      "severity": "medium",
      "rule_type": "deterministic",
      "verifiable_criteria": "Check page numbers are sequential.",
      "validation_intent": "Ensure navigation.",
      "typical_phrases": ["1", "2", "3"],
      "keywords": ["page number"],
      "applies_to_sections": ["footer"]
    },
    {
      "rule_id": "GDP-12",
      "title": "Readability Within Acceptable Range",
      "category": "language",
      "severity": "low",
      "rule_type": "semantic",
      "verifiable_criteria": "Assess readability level.",
      "validation_intent": "Ensure clarity.",
      "typical_phrases": ["paragraph text"],
      "keywords": ["readability"],
      "applies_to_sections": ["body", "full"],
      "always_include": true
    },
    {
      "rule_id": "GDP-13",
      "title": "Footer Contains At Least One of (Doc ID / Page Number / Confidentiality)",
      "category": "footer",
      "severity": "high",
      "rule_type": "deterministic",
      "verifiable_criteria": "Check whether the footer contains one or more of the following: Document ID, Page number, or Confidentiality statement. If at least one is present, consider the rule as passed. Only fail if none of these elements are found.",
      "validation_intent": "Ensure compliance.",
      "typical_phrases": ["CONFIDENTIAL", "DOC ID"],
      "keywords": ["footer", "confidential", "doc id", "page"],
      "applies_to_sections": ["footer"]
    }
  ]
}